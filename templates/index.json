    "custom_liquid_NNXwbd": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": false,
        "liquid": "<div class=\"lumoria-faq\" id=\"lumoria-faq-{{ section.id }}\">\n    <style>\n        #lumoria-faq-{{ section.id }}{\n            --faq-border:#EAEAEA;\n            --faq-text:#111;\n            --faq-subtle:#666;\n            --faq-accent:#000;\n            --faq-gap:10px;\n            max-width:820px;\n            margin:0 auto;\n            font-family:inherit;\n            padding:20px 0; /* ✅ ajout du padding haut/bas */\n        }\n        #lumoria-faq-{{ section.id }} .faq-heading{text-align:center;margin-bottom:12px;}\n        #lumoria-faq-{{ section.id }} .faq-heading .h1{display:inline-block;font-size:clamp(28px,4.5vw,40px);line-height:1.15;font-weight:800;letter-spacing:.2px;}\n        #lumoria-faq-{{ section.id }} .faq-list{border-top:1px solid var(--faq-border);}\n        #lumoria-faq-{{ section.id }} details{border-bottom:1px solid var(--faq-border);}\n        #lumoria-faq-{{ section.id }} summary{list-style:none;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:var(--faq-gap);padding:14px 6px;}\n        #lumoria-faq-{{ section.id }} summary::-webkit-details-marker{display:none;}\n        #lumoria-faq-{{ section.id }} .summary-left{display:flex;align-items:center;gap:12px;min-width:0;}\n        #lumoria-faq-{{ section.id }} .icon-bubble{width:34px;height:34px;border:1px solid var(--faq-border);border-radius:50%;display:grid;place-items:center;flex:0 0 34px;background:#fff;}\n        #lumoria-faq-{{ section.id }} .icon-bubble svg{width:18px;height:18px;}\n        #lumoria-faq-{{ section.id }} .faq-title{font-size:16px;line-height:1.35;color:var(--faq-text);font-weight:700;margin:0;}\n        #lumoria-faq-{{ section.id }} .caret{width:10px;height:10px;flex:0 0 10px;transform:rotate(0deg);transition:transform .2s ease;color:var(--faq-accent);}\n        #lumoria-faq-{{ section.id }} details[open] .caret{transform:rotate(180deg);}\n        #lumoria-faq-{{ section.id }} .faq-content{padding:0 6px 14px 52px;color:#222;font-size:15px;line-height:1.6;}\n        #lumoria-faq-{{ section.id }} .faq-content p{margin:0 0 10px 0;}\n        #lumoria-faq-{{ section.id }} .faq-content ul{margin:0 0 10px 18px;}\n        #lumoria-faq-{{ section.id }} .faq-content strong{color:#000;}\n        @media (max-width: 480px){\n            #lumoria-faq-{{ section.id }} .faq-content{padding-left:46px;}\n            #lumoria-faq-{{ section.id }} .faq-title{font-size:15px;}\n        }\n    </style>\n\n    <div class=\"faq-heading\">\n        <h2 class=\"h1\">FAQ</h2>\n    </div>\n\n    <div class=\"faq-list\">\n\n        <details>\n            <summary>\n                <div class=\"summary-left\">\n                    <span class=\"icon-bubble\" aria-hidden=\"true\">\n                        <svg viewBox=\"0 0 20 20\" fill=\"currentColor\">\n                            <path d=\"M18 10c0 3.59-3.58 6.5-8 6.5-.9 0-1.77-.11-2.6-.33L3.5 17.9a.8.8 0 0 1-1.03-.97l.8-2.62C2.49 13.23 2 11.66 2 10 2 6.41 5.58 3.5 10 3.5s8 2.91 8 6.5Z\"/>\n                        </svg>\n                    </span>\n                    <h3 class=\"faq-title\">À qui s’adresse Lumoria&nbsp;?</h3>\n                </div>\n                <svg class=\"caret\" viewBox=\"0 0 10 6\">\n                    <path d=\"M9.354.646a.5.5 0 0 0-.708 0L5 4.293 1.354.646a.5.5 0 1 0-.708.708l4 4a.5.5 0 0 0 .708 0l4-4a.5.5 0 0 0 0-.708Z\"/>\n                </svg>\n            </summary>\n            <div class=\"faq-content\">\n                <p>Les utilisateurs de <strong>Lumoria</strong> sont des personnes qui souhaitent <strong>perdre du poids</strong>, <strong>renforcer leur confiance</strong>, <strong>améliorer leur posture</strong>, <strong>gagner en énergie</strong> et paraître plus <strong>toniques</strong> au quotidien.</p>\n            </div>\n        </details>\n\n        <details>\n            <summary>\n                <div class=\"summary-left\">\n                    <span class=\"icon-bubble\" aria-hidden=\"true\">\n                        <svg viewBox=\"0 0 20 20\" fill=\"currentColor\">\n                            <path d=\"M18 10c0 3.59-3.58 6.5-8 6.5-.9 0-1.77-.11-2.6-.33L3.5 17.9a.8.8 0 0 1-1.03-.97l.8-2.62C2.49 13.23 2 11.66 2 10 2 6.41 5.58 3.5 10 3.5s8 2.91 8 6.5Z\"/>\n                        </svg>\n                    </span>\n                    <h3 class=\"faq-title\">Comment fonctionne le débardeur Lumoria&nbsp;?</h3>\n                </div>\n                <svg class=\"caret\" viewBox=\"0 0 10 6\">\n                    <path d=\"M9.354.646a.5.5 0 0 0-.708 0L5 4.293 1.354.646a.5.5 0 1 0-.708.708l4 4a.5.5 0 0 0 .708 0l4-4a.5.5 0 0 0 0-.708Z\"/>\n                </svg>\n            </summary>\n            <div class=\"faq-content\">\n                <p><strong>Lumoria</strong> est conçu avec un <strong>tissu haute performance</strong> qui stimule naturellement le corps. Ses <strong>fibres minérales</strong> favorisent la circulation, aident à se sentir plus énergique et améliorent la posture. Porté régulièrement, il affine la silhouette et renforce le bien-être global.</p>\n            </div>\n        </details>\n\n        <details>\n            <summary>\n                <div class=\"summary-left\">\n                    <span class=\"icon-bubble\" aria-hidden=\"true\">\n                        <svg viewBox=\"0 0 20 20\" fill=\"currentColor\">\n                            <path d=\"M18 10c0 3.59-3.58 6.5-8 6.5-.9 0-1.77-.11-2.6-.33L3.5 17.9a.8.8 0 0 1-1.03-.97l.8-2.62C2.49 13.23 2 11.66 2 10 2 6.41 5.58 3.5 10 3.5s8 2.91 8 6.5Z\"/>\n                        </svg>\n                    </span>\n                    <h3 class=\"faq-title\">Combien de temps avant de voir une différence&nbsp;?</h3>\n                </div>\n                <svg class=\"caret\" viewBox=\"0 0 10 6\">\n                    <path d=\"M9.354.646a.5.5 0 0 0-.708 0L5 4.293 1.354.646a.5.5 0 1 0-.708.708l4 4a.5.5 0 0 0 .708 0l4-4a.5.5 0 0 0 0-.708Z\"/>\n                </svg>\n            </summary>\n            <div class=\"faq-content\">\n                <p>Les résultats varient, mais la majorité des utilisateurs observent une <strong>amélioration visible en 30 jours</strong>. Pour des résultats optimaux, portez-le quotidiennement et adoptez une <strong>hygiène de vie saine</strong>.</p>\n            </div>\n        </details>\n\n        <details>\n            <summary>\n                <div class=\"summary-left\">\n                    <span class=\"icon-bubble\" aria-hidden=\"true\">\n                        <svg viewBox=\"0 0 20 20\" fill=\"currentColor\">\n                            <path d=\"M18 10c0 3.59-3.58 6.5-8 6.5-.9 0-1.77-.11-2.6-.33L3.5 17.9a.8.8 0 0 1-1.03-.97l.8-2.62C2.49 13.23 2 11.66 2 10 2 6.41 5.58 3.5 10 3.5s8 2.91 8 6.5Z\"/>\n                        </svg>\n                    </span>\n                    <h3 class=\"faq-title\">Et si la taille ne convient pas&nbsp;?</h3>\n                </div>\n                <svg class=\"caret\" viewBox=\"0 0 10 6\">\n                    <path d=\"M9.354.646a.5.5 0 0 0-.708 0L5 4.293 1.354.646a.5.5 0 1 0-.708.708l4 4a.5.5 0 0 0 .708 0l4-4a.5.5 0 0 0 0-.708Z\"/>\n                </svg>\n            </summary>\n            <div class=\"faq-content\">\n                <p>Pas d’inquiétude. Si la taille ne convient pas, contactez-nous à <a href=\"mailto:contact@getlumoria.com\"><strong>contact@getlumoria.com</strong></a> pour procéder à un échange.</p>\n            </div>\n        </details>\n\n        <details>\n            <summary>\n                <div class=\"summary-left\">\n                    <span class=\"icon-bubble\" aria-hidden=\"true\">\n                        <svg viewBox=\"0 0 20 20\" fill=\"currentColor\">\n                            <path d=\"M18 10c0 3.59-3.58 6.5-8 6.5-.9 0-1.77-.11-2.6-.33L3.5 17.9a.8.8 0 0 1-1.03-.97l.8-2.62C2.49 13.23 2 11.66 2 10 2 6.41 5.58 3.5 10 3.5s8 2.91 8 6.5Z\"/>\n                        </svg>\n                    </span>\n                    <h3 class=\"faq-title\">Quels sont les délais de livraison&nbsp;?</h3>\n                </div>\n                <svg class=\"caret\" viewBox=\"0 0 10 6\">\n                    <path d=\"M9.354.646a.5.5 0 0 0-.708 0L5 4.293 1.354.646a.5.5 0 1 0-.708.708l4 4a.5.5 0 0 0 .708 0l4-4a.5.5 0 0 0 0-.708Z\"/>\n                </svg>\n            </summary>\n            <div class=\"faq-content\">\n                <p><strong>France &amp; Belgique.</strong> Les commandes sont traitées sous <strong>24h</strong>.</p>\n                <p>Délai d’acheminement estimé&nbsp;: <strong>8 à 12 jours ouvrés</strong> pour la France et la Belgique (numéro de suivi envoyé par e-mail).</p>\n            </div>\n        </details>\n\n        <details>\n            <summary>\n                <div class=\"summary-left\">\n                    <span class=\"icon-bubble\" aria-hidden=\"true\">\n                        <svg viewBox=\"0 0 20 20\" fill=\"currentColor\">\n                            <path d=\"M18 10c0 3.59-3.58 6.5-8 6.5-.9 0-1.77-.11-2.6-.33L3.5 17.9a.8.8 0 0 1-1.03-.97l.8-2.62C2.49 13.23 2 11.66 2 10 2 6.41 5.58 3.5 10 3.5s8 2.91 8 6.5Z\"/>\n                        </svg>\n                    </span>\n                    <h3 class=\"faq-title\">Lumoria passe-t-il en machine&nbsp;?</h3>\n                </div>\n                <svg class=\"caret\" viewBox=\"0 0 10 6\">\n                    <path d=\"M9.354.646a.5.5 0 0 0-.708 0L5 4.293 1.354.646a.5.5 0 1 0-.708.708l4 4a.5.5 0 0 0 .708 0l4-4a.5.5 0 0 0 0-.708Z\"/>\n                </svg>\n            </summary>\n            <div class=\"faq-content\">\n                <p><strong>Oui</strong>, mais il est conseillé de le laver à <strong>basse température</strong> afin de préserver le tissu et la compression.</p>\n            </div>\n        </details>\n\n        <details>\n            <summary>\n                <div class=\"summary-left\">\n                    <span class=\"icon-bubble\" aria-hidden=\"true\">\n                        <svg viewBox=\"0 0 20 20\" fill=\"currentColor\">\n                            <path d=\"M18 10c0 3.59-3.58 6.5-8 6.5-.9 0-1.77-.11-2.6-.33L3.5 17.9a.8.8 0 0 1-1.03-.97l.8-2.62C2.49 13.23 2 11.66 2 10 2 6.41 5.58 3.5 10 3.5s8 2.91 8 6.5Z\"/>\n                        </svg>\n                    </span>\n                    <h3 class=\"faq-title\">De quoi est composé Lumoria&nbsp;?</h3>\n                </div>\n                <svg class=\"caret\" viewBox=\"0 0 10 6\">\n                    <path d=\"M9.354.646a.5.5 0 0 0-.708 0L5 4.293 1.354.646a.5.5 0 1 0-.708.708l4 4a.5.5 0 0 0 .708 0l4-4a.5.5 0 0 0 0-.708Z\"/>\n                </svg>\n            </summary>\n            <div class=\"faq-content\">\n                <p><strong>80 % nylon</strong> — <strong>20 % élasthanne</strong>.</p>\n            </div>\n        </details>\n\n    </div>\n</div>",
        "background": "",
