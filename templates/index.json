            "liquid": "<div class=\"order-tracking-timeline\">\n  <style>\n    .order-tracking-timeline {\n      padding: 10px 0px;\n      max-width: 600px;\n      margin: 0 auto;\n    }\n    \n    .timeline-container {\n      display: flex;\n      justify-content: space-between;\n      align-items: flex-start;\n      position: relative;\n      margin-bottom: 10px;\n    }\n    \n    .timeline-line {\n      position: absolute;\n      top: 25px;\n      left: 25%;\n      right: 25%;\n      height: 3px;\n      background: #e0e0e0;\n      z-index: 0;\n    }\n    \n    .timeline-progress {\n      position: absolute;\n      top: 0;\n      left: 0;\n      height: 100%;\n      background: #2c3e50;\n      transition: width 0.5s ease;\n    }\n    \n    .timeline-step {\n      flex: 1;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      position: relative;\n      z-index: 1;\n    }\n    \n    .step-icon {\n      width: 50px;\n      height: 50px;\n      border-radius: 50%;\n      background: #e0e0e0;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      margin-bottom: 12px;\n      transition: all 0.3s ease;\n    }\n    \n    .step-icon.active {\n      background: #2c3e50;\n    }\n    \n    .step-icon.completed {\n      background: #27ae60;\n    }\n    \n    .step-icon svg {\n      width: 24px;\n      height: 24px;\n      fill: white;\n    }\n    \n    .step-date {\n      font-size: 14px;\n      font-weight: 600;\n      color: #2c3e50;\n      margin-bottom: 4px;\n      text-align: center;\n    }\n    \n    .step-label {\n      font-size: 13px;\n      color: #666;\n      text-align: center;\n    }\n    \n    .step-icon.inactive svg {\n      fill: #999;\n    }\n  </style>\n\n  {% comment %} Récupération de la date actuelle en UTC {% endcomment %}\n  {% assign current_timestamp = 'now' | date: '%s' %}\n  \n  {% comment %} Calcul des dates (jour actuel + décalages) {% endcomment %}\n  {% assign order_date = current_timestamp | date: '%d %b' %}\n  \n  {% assign shipping_start = current_timestamp | plus: 86400 | date: '%d %b' %}\n  {% assign shipping_end = current_timestamp | plus: 172800 | date: '%d %b' %}\n  \n  {% comment %} Détermination du statut actuel {% endcomment %}\n  {% assign days_since_order = 0 %}\n  {% if order.created_at %}\n    {% assign order_timestamp = order.created_at | date: '%s' %}\n    {% assign days_diff = current_timestamp | minus: order_timestamp | divided_by: 86400 %}\n    {% assign days_since_order = days_diff %}\n  {% endif %}\n  \n  {% if days_since_order >= 1 %}\n    {% assign current_status = 'shipped' %}\n    {% assign progress_width = '100%' %}\n  {% else %}\n    {% assign current_status = 'ordered' %}\n    {% assign progress_width = '0%' %}\n  {% endif %}\n\n  <div class=\"timeline-container\">\n    <div class=\"timeline-line\">\n      <div class=\"timeline-progress\" style=\"width: {{ progress_width }}\"></div>\n    </div>\n    \n    <!-- Étape 1: Commandé -->\n    <div class=\"timeline-step\">\n      <div class=\"step-icon {% if current_status == 'ordered' or current_status == 'shipped' %}completed{% endif %}\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\">\n          <path d=\"M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z\"/>\n        </svg>\n      </div>\n      <div class=\"step-date\">{{ order_date }}</div>\n      <div class=\"step-label\">Commandé</div>\n    </div>\n    \n    <!-- Étape 2: Expédié -->\n    <div class=\"timeline-step\">\n      <div class=\"step-icon {% if current_status == 'shipped' %}completed{% else %}inactive{% endif %}\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\">\n          <path d=\"M18 18.5c.83 0 1.5-.67 1.5-1.5s-.67-1.5-1.5-1.5-1.5.67-1.5 1.5.67 1.5 1.5 1.5zm1.5-9H17V12h4.46L19.5 9.5zM6 18.5c.83 0 1.5-.67 1.5-1.5s-.67-1.5-1.5-1.5-1.5.67-1.5 1.5.67 1.5 1.5 1.5zM20 8l3 4v5h-2c0 1.66-1.34 3-3 3s-3-1.34-3-3H9c0 1.66-1.34 3-3 3s-3-1.34-3-3H1V6c0-1.11.89-2 2-2h14v4h3zM3 6v9h.76c.55-.61 1.35-1 2.24-1s1.69.39 2.24 1H15V6H3z\"/>\n        </svg>\n      </div>\n      <div class=\"step-date\">{{ shipping_start }} - {{ shipping_end }}</div>\n      <div class=\"step-label\">Expédié</div>\n    </div>\n  </div>\n</div>\n\n<!-- ✅ Badges : Garantie + Stock limité -->\n<div style=\"display: flex; gap: 5px; align-items: center; z-index: 21; flex-wrap: wrap; margin-bottom: 10px;\">\n  <!-- Badge 90 jours satisfait ou remboursé -->\n  <div style=\"background-color: #e0f4e8; color: #004d00; padding: 2px 6px; border-radius: 4px; font-weight: bold; display: flex; align-items: center; font-size: 11px; line-height: 1;\">\n    <svg style=\"width: 12px; height: 12px; margin-right: 4px;\" viewBox=\"0 0 24 24\" fill=\"#004d00\"><path d=\"M12 2C9.24 2 7 4.24 7 7V10H5C3.9 10 3 10.9 3 12V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V12C21 10.9 20.1 10 19 10H17V7C17 4.24 14.76 2 12 2Z\"/></svg>\n    90J Satisfait ou remboursé\n  </div>\n\n  <!-- Badge Stock limité -->\n  <div style=\"background-color: #fee7e7; color: #b22222; padding: 2px 6px; border-radius: 4px; font-weight: bold; display: flex; align-items: center; font-size: 11px; line-height: 1;\">\n    <svg style=\"width: 12px; height: 12px; margin-right: 4px;\" viewBox=\"0 0 24 24\" fill=\"#b22222\"><circle cx=\"12\" cy=\"12\" r=\"10\" stroke=\"#b22222\" stroke-width=\"2\" fill=\"none\"/><line x1=\"12\" y1=\"12\" x2=\"12\" y2=\"6\" stroke=\"#b22222\" stroke-width=\"2\"/><line x1=\"12\" y1=\"12\" x2=\"16\" y2=\"12\" stroke=\"#b22222\" stroke-width=\"2\"/></svg>\n    STOCK LIMITÉ !\n  </div>\n</div>\n\n<!-- ✅ eBook offert -->\n<div style=\"font-size: 14px; line-height: 1.4; font-family: 'Poppins', sans-serif; margin: 10px 0;\">\n  <b>📘 eBook OFFERT : \"Les 7 Secrets pour une Posture Droite et une Confiance Instantanée\" (Valeur&nbsp;: 24,90€)</b>\n</div>\n\n<!-- ✅ Logos de paiement SVG inline (publics) -->\n<ul class=\"payment-badges\" role=\"list\" style=\"display: flex; flex-wrap: wrap; gap: 8px; align-items: center; margin-top: 10px;\">\n  <!-- 🧾 SVGs collés ici (les tiens) -->\n  <!-- Tu colles ici tout ton bloc SVG que tu as partagé (déjà formaté et prêt à l'emploi) -->\n</ul>"
          }
        },
        "liquid_iz8Mqd": {
          "type": "liquid",
          "settings": {
            "liquid": "<div style=\"background-color: #F4F6F9; border: 1px solid #e0e0e0; border-radius: 12px; padding: 18px 20px; max-width: 420px; font-family: inherit; font-size: 14px; color: #000; text-align: left; line-height: 1.7;\">\n  \n  <!-- Header : Avatar + Infos -->\n  <div style=\"display: flex; align-items: center; gap: 12px; margin-bottom: 12px;\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0681/1290/8348/files/image_2025-10-24_101835136.png?v=1761297458\" \n         alt=\"Julien M.\" \n         style=\"width: 52px; height: 52px; border-radius: 50%;\">\n    \n    <div>\n      <div style=\"font-weight: 700; font-size: 15px;\">Julien M.</div>\n      \n      <div style=\"display: flex; align-items: center; color: #6A5ACD; font-size: 12px; margin-top: 3px;\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" fill=\"#6A5ACD\" viewBox=\"0 0 16 16\" style=\"margin-right: 4px;\">\n          <path d=\"M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z\"/>\n        </svg>\n        Avis vérifié\n      </div>\n      \n      <!-- Stars -->\n      <div style=\"margin-top: 6px;\">\n        {% for i in (1..5) %}\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"13px\" height=\"13px\" fill=\"#F26827FF\" viewBox=\"0 0 16 16\" style=\"margin-right: 2px;\">\n            <path d=\"M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z\"/>\n          </svg>\n        {% endfor %}\n      </div>\n    </div>\n  </div>\n\n  <!-- Témoignage -->\n  <div style=\"margin-top: 14px;\">\n    <p>\n      Je pensais que c’était juste un débardeur gainant… mais le <strong>Lumoria™ 2.0</strong> m’a vraiment surpris. \n      Posture redressée, ventre comprimé, <strong>effet visuel direct</strong>.  \n      <strong>Ma copine me dit que j’ai minci</strong> — et c’est vrai, ma taille s’est affinée depuis que je le porte tous les jours.  \n      C’est pas un simple vêtement, <strong>c’est un déclencheur</strong>.\n    </p>\n  </div>\n</div>"
          }
        }
