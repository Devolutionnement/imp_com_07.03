    "custom_liquid_97kBLG": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": false,
        "liquid": "<!-- Lumoria - Section icônes (fond noir, style premium masculin) -->\n<style>\n  .lumoria-iconbar--dark {\n    background: #0E0E0E;\n    color: #FFFFFF;\n    padding: 50px 0;\n    text-align: center;\n  }\n\n  .lumoria-iconbar--dark .multicolumn-list {\n    display: flex;\n    flex-direction: column;\n    gap: 60px;\n    justify-content: center;\n    align-items: center;\n  }\n\n  .lumoria-iconbar--dark .icon-bar-card__icon {\n    margin-bottom: 18px;\n  }\n\n  .lumoria-iconbar--dark svg {\n    width: 48px;\n    height: 48px;\n    stroke: #67A8FF; /* 🔵 Icônes bleues Lumoria */\n    fill: none;\n    stroke-width: 1.6;\n    transition: stroke 0.3s ease;\n  }\n\n  /* Effet hover subtil */\n  .lumoria-iconbar--dark .icon-bar-card:hover svg {\n    stroke: #8CC9FF;\n  }\n\n  .lumoria-iconbar--dark h3 {\n    font-family: 'Poppins', sans-serif;\n    font-weight: 700;\n    font-size: 20px;\n    color: #FFFFFF;\n    margin: 8px 0 6px;\n  }\n\n  .lumoria-iconbar--dark p {\n    font-family: 'Poppins', sans-serif;\n    font-weight: 400;\n    font-size: 14px;\n    color: #CFCFCF;\n    margin: 0;\n  }\n\n  @media (min-width: 750px) {\n    .lumoria-iconbar--dark .multicolumn-list {\n      flex-direction: row;\n      gap: 80px;\n    }\n  }\n</style>\n\n<div class=\"lumoria-iconbar--dark page-width isolate\">\n  <ul class=\"multicolumn-list\" role=\"list\">\n\n    <!-- Bloc 1 : Preuve sociale -->\n    <li class=\"multicolumn-list__item grid__item center\">\n      <div class=\"icon-bar-card multicolumn-card content-container\">\n        <div class=\"icon-bar-card__icon\">\n          <!-- Cœur -->\n          <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 20 20\">\n            <path d=\"M10 5.2393L8.5149 3.77392C6.79996 2.08174 4.01945 2.08174 2.30451 3.77392C0.589562 5.4661 0.589563 8.2097 2.30451 9.90188L10 17.4952L17.6955 9.90188C19.4104 8.2097 19.4104 5.4661 17.6955 3.77392C15.9805 2.08174 13.2 2.08174 11.4851 3.77392L10 5.2393Z\"/>\n          </svg>\n        </div>\n        <h3>Déjà adopté par 9.800+ hommes</h3>\n        <p>Des clients qui transforment leur posture, leur silhouette et leur confiance en un seul geste.</p>\n      </div>\n    </li>\n\n    <!-- Bloc 2 : Expédition rapide -->\n    <li class=\"multicolumn-list__item grid__item center\">\n      <div class=\"icon-bar-card multicolumn-card content-container\">\n        <div class=\"icon-bar-card__icon\">\n          <!-- Camion -->\n          <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 20 20\">\n            <path d=\"M0.5 3.25H10.65V13.66H2.68V14.66H0.5V3.75\" />\n            <path d=\"M19.5 14.66H17.31V13.66H19V7.69L11.15 5.07V6.11L19.62 7.21\" />\n            <path d=\"M5.15 11.62A2.56 2.56 0 1 1 2.59 14.19A2.56 2.56 0 0 1 5.15 11.62Z\" />\n            <path d=\"M14.96 11.62A2.56 2.56 0 1 1 12.4 14.19A2.56 2.56 0 0 1 14.96 11.62Z\" />\n          </svg>\n        </div>\n        <h3>Livraison rapide & gratuite</h3>\n        <p>Commandez aujourd'hui, portez-le dans environ 5 jours ouvrés. Expédition suivie offerte en France.</p>\n      </div>\n    </li>\n\n    <!-- Bloc 3 : Garantie sans risque -->\n    <li class=\"multicolumn-list__item grid__item center\">\n      <div class=\"icon-bar-card multicolumn-card content-container\">\n        <div class=\"icon-bar-card__icon\">\n          <!-- Cadenas -->\n          <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 20 20\">\n            <path d=\"M3.5 7.12H16.5V19H3.5V7.12Z\" />\n            <path d=\"M10 10.43A1.49 1.49 0 1 1 10 13.41A1.49 1.49 0 0 1 10 10.43Z\" />\n            <path d=\"M6.24 6.12V3.76C6.24 1.68 7.92 0 10 0C12.08 0 13.76 1.68 13.76 3.76V6.12\" />\n          </svg>\n        </div>\n        <h3>Essayez-le sans stress</h3>\n        <p>30 jours pour tester. Si vous n'êtes pas satisfait, on vous rembourse sans poser de question.</p>\n      </div>\n    </li>\n\n  </ul>\n</div>",
