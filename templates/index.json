   align-items: center;\n      gap: 8px;\n      font-size: 15px;\n      flex-wrap: wrap;\n    }\n    .tp-logo {\n      height: 24px;\n      width: auto;\n      margin-top: -2px;\n    }\n    @media (max-width: 480px) {\n      .tp-clean h2 { font-size: 20px; }\n      .rating-text, .rating-score { font-size: 15px; }\n      .tp-bottom { font-size: 14px; }\n      .stars-img { width: 112px; margin-right: 6px; }\n    }\n  </style>\n</div>",
