    "custom_liquid_PLLfdJ": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<!-- Lumoria — Slider vidéos plein portrait (dots + swipe, taille ajustable + loop) -->\n<div class=\"lumoria-video-portrait\" id=\"lumoria-video-{{ section.id }}\">\n  <style>\n    #lumoria-video-{{ section.id }}{\n      --gap:10px;\n      --radius:12px;\n      --dot:7px;\n      --slide-width:130px; /* ⇦ ajuste la taille ici */\n      font-family:inherit; background:#fff; padding:12px 0 22px;\n    }\n    #lumoria-video-{{ section.id }} .heading{\n      display:flex; align-items:center; justify-content:center; gap:6px;\n      font-weight:700; font-size:16px; margin-bottom:12px; color:#000;\n    }\n    #lumoria-video-{{ section.id }} .heading svg{ width:18px; height:18px; color:#f5b301; }\n\n    #lumoria-video-{{ section.id }} .viewport{ overflow:hidden; }\n    #lumoria-video-{{ section.id }} .track{\n      display:flex; gap:var(--gap); transition:transform .35s ease;\n      will-change:transform; touch-action:pan-y;\n    }\n\n    #lumoria-video-{{ section.id }} .slide{\n      flex:0 0 var(--slide-width);\n      aspect-ratio:9 / 16; border-radius:var(--radius); overflow:hidden;\n      background:#000; box-shadow:0 2px 8px rgba(0,0,0,.08);\n    }\n    #lumoria-video-{{ section.id }} video{\n      width:100%; height:100%; object-fit:contain; background:#000; display:block; border-radius:var(--radius);\n    }\n\n    #lumoria-video-{{ section.id }} .dots{ display:flex; justify-content:center; gap:7px; margin-top:12px; }\n    #lumoria-video-{{ section.id }} .dot{\n      width:var(--dot); height:var(--dot); border-radius:50%; background:#d0d0d0;\n      cursor:pointer; transition:transform .15s ease, background .2s ease;\n    }\n    #lumoria-video-{{ section.id }} .dot.active{ background:#111; transform:scale(1.2); }\n  </style>\n\n  <!-- ⭐ Heading -->\n  <div class=\"heading\">\n    <svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 17.3l-6.18 3.64 1.64-7.03L2 8.77l7.19-.62L12 1.5l2.81 6.65 7.19.62-5.46 5.14 1.64 7.03z\"/></svg>\n    10 000+ Clients Satisfaits !\n  </div>\n\n  <div class=\"viewport\">\n    <div class=\"track\">\n      {% assign videos = \"\n        https://cdn.shopify.com/videos/c/o/v/3275007fea7647069ac2b0dfac1f0193.mp4,\n        https://cdn.shopify.com/videos/c/o/v/f3633bc1da904679830bf1e0b2aa9362.mp4,\n        https://cdn.shopify.com/videos/c/o/v/a7251e77ca644bd89c7897c9b35d269b.mp4,\n        https://cdn.shopify.com/videos/c/o/v/760e2904d9bc466f83b315d5ebdeb4c3.mp4,\n        https://cdn.shopify.com/videos/c/o/v/b43a1630b9124d93b8db01d6f841553e.mp4\n      \" | split: \",\" %}\n\n      {% for video in videos %}\n      <div class=\"slide\">\n        <video playsinline autoplay muted loop preload=\"metadata\">\n          <source src=\"{{ video | strip }}\" type=\"video/mp4\">\n        </video>\n      </div>\n      {% endfor %}\n    </div>\n  </div>\n\n  <div class=\"dots\" role=\"tablist\" aria-label=\"Pagination\"></div>\n\n  <script>\n    (function(){\n      const root = document.getElementById(\"lumoria-video-{{ section.id }}\");\n      const viewport = root.querySelector(\".viewport\");\n      const track = root.querySelector(\".track\");\n      const slides = Array.from(track.children);\n      const dotsWrap = root.querySelector(\".dots\");\n\n      const styles = getComputedStyle(root);\n      const slideW = parseFloat(styles.getPropertyValue(\"--slide-width\"));\n      const gap = parseFloat(styles.getPropertyValue(\"--gap\"));\n\n      let perView = 1, pages = 1, page = 0, step = 0, maxScroll = 0, totalWidth = 0;\n\n      function measure(){\n        perView = Math.max(1, Math.floor((viewport.clientWidth + gap) / (slideW + gap)));\n        totalWidth = slides.length * (slideW + gap) - gap;\n        const vpw = viewport.clientWidth;\n        step = perView * (slideW + gap);\n        maxScroll = Math.max(0, totalWidth - vpw);\n\n        // Nombre de pages réelles qui ne dépassent jamais la fin\n        pages = Math.max(1, Math.ceil(maxScroll / step) + 1);\n\n        buildDots();\n        goTo(Math.min(page, pages-1), false);\n      }\n\n      function buildDots(){\n        dotsWrap.innerHTML = \"\";\n        for(let i=0;i<pages;i++){\n          const b=document.createElement(\"button\");\n          b.type=\"button\"; b.className=\"dot\"+(i===page?\" active\":\"\");\n          b.addEventListener(\"click\",()=>goTo(i, true));\n          dotsWrap.appendChild(b);\n        }\n      }\n\n      function applyOffset(px){\n        track.style.transform = `translate3d(${-px}px,0,0)`;\n      }\n\n      function goTo(p, withLoop){\n        // loop: si on dépasse, on revient au début / fin\n        if (withLoop) {\n          if (p >= pages) p = 0;\n          if (p < 0) p = pages - 1;\n        }\n        page = Math.max(0, Math.min(p, pages-1));\n        const target = Math.min(page * step, maxScroll);\n        track.style.transition = \"transform .35s ease\";\n        applyOffset(target);\n        dotsWrap.querySelectorAll(\".dot\").forEach((d,i)=>d.classList.toggle(\"active\", i===page));\n      }\n\n      // Swipe\n      let startX=0, dragging=false, base=0;\n      function currentOffset(){\n        const m = track.style.transform.match(/translate3d\\((-?\\d+(\\.\\d+)?)px/);\n        return m ? parseFloat(m[1]) * -1 : 0;\n      }\n\n      viewport.addEventListener(\"pointerdown\", e=>{\n        dragging=true; startX=e.clientX; base=currentOffset();\n        track.style.transition=\"none\";\n      });\n      viewport.addEventListener(\"pointermove\", e=>{\n        if(!dragging) return;\n        const dx=e.clientX-startX;\n        let pos = Math.min(Math.max(base - dx, 0), maxScroll);\n        applyOffset(pos);\n      });\n      function endDrag(e){\n        if(!dragging) return;\n        dragging=false;\n        const dx=e.clientX-startX;\n        const th=(slideW+gap)*0.3;\n\n        if(dx<-th) goTo(page+1, true);         // vers la droite => page suivante (loop)\n        else if(dx>th) goTo(page-1, true);     // vers la gauche  => page précédente (loop)\n        else goTo(page, false);\n      }\n      viewport.addEventListener(\"pointerup\", endDrag);\n      viewport.addEventListener(\"pointercancel\", endDrag);\n\n      // Recalcule à chaque resize pour garder 2,5 visibles si tu ajustes --slide-width\n      let rAF;\n      window.addEventListener(\"resize\", ()=>{\n        cancelAnimationFrame(rAF);\n        rAF = requestAnimationFrame(measure);\n      });\n\n      measure();\n    })();\n  </script>\n</div>",
        "background": "",
        "background_gradient": "",
        "text_color": ""
      }
    },
