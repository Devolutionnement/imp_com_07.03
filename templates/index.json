    "custom_liquid_m4Q9G6": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": false,
        "liquid": "<!-- ====== Bloc Avis (sans galerie photos) ====== -->\n<div id=\"reviews-block\" class=\"rv-wrap\" role=\"region\" aria-label=\"Avis clients\">\n  <style>\n    #reviews-block { font-family: inherit; background:#fff; padding:24px 0; }\n    #reviews-block .rv-box { max-width:880px; margin:0 auto; padding:0 14px; text-align:center; }\n\n    .rv-title{font-size:28px;font-weight:700;color:#111;margin:0 0 12px}\n    .rv-starsline{display:inline-flex;align-items:center;gap:10px;color:#1b7b5c;margin:2px 0}\n    .rv-stars{display:inline-flex;gap:3px}\n    .rv-star{width:18px;height:18px;display:inline-block}\n    .rv-star svg{width:100%;height:100%}\n    .rv-score{color:#2b2b2b;font-weight:600}\n    .rv-sub{color:#6b6b6b;display:inline-flex;align-items:center;gap:6px;margin-top:4px}\n    .rv-check{width:16px;height:16px}\n\n    .rv-histo{margin:16px 0 18px;display:inline-block;text-align:left;width:420px;max-width:100%}\n    .rv-row{display:grid;grid-template-columns:110px 1fr 44px;align-items:center;gap:10px;margin:6px 0}\n    .stars-small{display:inline-flex;gap:2px}\n    .rv-bar{height:12px;background:#ececec;border-radius:3px;overflow:hidden}\n    .rv-bar>span{display:block;height:100%;background:#62c3a1;border-radius:3px}\n    .rv-qty{font-size:13px;color:#636363;text-align:right;min-width:44px}\n\n    .rv-btn{display:block;width:100%;max-width:520px;margin:18px auto;padding:12px 16px;text-align:center;background:#62c3a1;color:#fff;font-weight:700;border-radius:6px;text-decoration:none}\n    .rv-btn:hover{opacity:.95}\n\n    .rv-divider{height:1px;background:#efefef;margin:20px 0}\n  </style>\n\n  <div class=\"rv-box\">\n    <h2 class=\"rv-title\">Avis clients</h2>\n\n    <div class=\"rv-starsline\" aria-label=\"Note moyenne\">\n      <span class=\"rv-stars\">\n        {% for i in (1..5) %}\n          <span class=\"rv-star\"><svg viewBox=\"0 0 24 24\" fill=\"#62c3a1\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.88L18.2 22 12 18.56 5.8 22 7 14.15l-5-4.88 6.91-1.01L12 2z\"/></svg></span>\n        {% endfor %}\n      </span>\n      <span class=\"rv-score\">4,96 sur 5</span>\n    </div>\n\n    <div class=\"rv-sub\">\n      <span>Basé sur 1229 avis</span>\n      <svg class=\"rv-check\" viewBox=\"0 0 24 24\"><path fill=\"#62c3a1\" d=\"M9 16.2l-3.5-3.5L4 14.2 9 19l12-12-1.5-1.5z\"/></svg>\n    </div>\n\n    <!-- Histogramme -->\n    <div class=\"rv-histo\">\n      <div class=\"rv-row\">\n        <div class=\"stars-small\">\n          {% for i in (1..5) %}\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#62c3a1\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.88L18.2 22 12 18.56 5.8 22 7 14.15l-5-4.88 6.91-1.01L12 2z\"/></svg>\n          {% endfor %}\n        </div>\n        <div class=\"rv-bar\"><span style=\"width:96%\"></span></div>\n        <div class=\"rv-qty\">1177</div>\n      </div>\n      <div class=\"rv-row\">\n        <div class=\"stars-small\">\n          {% for i in (1..4) %}\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#62c3a1\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.88L18.2 22 12 18.56 5.8 22 7 14.15l-5-4.88 6.91-1.01L12 2z\"/></svg>\n          {% endfor %}\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#e1e1e1\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.88L18.2 22 12 18.56 5.8 22 7 14.15l-5-4.88 6.91-1.01L12 2z\"/></svg>\n        </div>\n        <div class=\"rv-bar\"><span style=\"width:4%\"></span></div>\n        <div class=\"rv-qty\">52</div>\n      </div>\n      <!-- 3, 2, 1 étoiles lignes -->\n      <div class=\"rv-row\">\n        <div class=\"stars-small\">\n          {% for i in (1..3) %}<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#62c3a1\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.88L18.2 22 12 18.56 5.8 22 7 14.15l-5-4.88 6.91-1.01L12 2z\"/></svg>{% endfor %}\n          {% for i in (1..2) %}<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#e1e1e1\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.88L18.2 22 12 18.56 5.8 22 7 14.15l-5-4.88 6.91-1.01L12 2z\"/></svg>{% endfor %}\n        </div>\n        <div class=\"rv-bar\"><span style=\"width:0%\"></span></div>\n        <div class=\"rv-qty\">0</div>\n      </div>\n      <div class=\"rv-row\">\n        <div class=\"stars-small\">\n          {% for i in (1..2) %}<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#62c3a1\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.88L18.2 22 12 18.56 5.8 22 7 14.15l-5-4.88 6.91-1.01L12 2z\"/></svg>{% endfor %}\n          {% for i in (1..3) %}<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#e1e1e1\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.88L18.2 22 12 18.56 5.8 22 7 14.15l-5-4.88 6.91-1.01L12 2z\"/></svg>{% endfor %}\n        </div>\n        <div class=\"rv-bar\"><span style=\"width:0%\"></span></div>\n        <div class=\"rv-qty\">0</div>\n      </div>\n      <div class=\"rv-row\">\n        <div class=\"stars-small\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#62c3a1\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.88L18.2 22 12 18.56 5.8 22 7 14.15l-5-4.88 6.91-1.01L12 2z\"/></svg>\n          {% for i in (1..4) %}<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#e1e1e1\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.88L18.2 22 12 18.56 5.8 22 7 14.15l-5-4.88 6.91-1.01L12 2z\"/></svg>{% endfor %}\n        </div>\n        <div class=\"rv-bar\"><span style=\"width:0%\"></span></div>\n        <div class=\"rv-qty\">0</div>\n      </div>\n    </div>\n\n    <a class=\"rv-btn\" href=\"javascript:void(0)\">Écrire un avis</a>\n  </div>\n</div>",
        "background": "",
