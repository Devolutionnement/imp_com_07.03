    "custom_liquid_UwCyzh": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": false,
        "liquid": "<!-- Lumoria - FAQ (Kompresní tílko pro muže, CZ) -->\n<div class=\"lumoria-faq\" id=\"lumoria-faq-{{ section.id }}\">\n  <style>\n    #lumoria-faq-{{ section.id }} { font-family: inherit; }\n    #lumoria-faq-{{ section.id }} .faq-item { border-bottom: 1px solid #e5e5e5; }\n    #lumoria-faq-{{ section.id }} .faq-head { display: flex; align-items: center; justify-content: space-between; cursor: pointer; padding: 14px 4px; }\n    #lumoria-faq-{{ section.id }} .faq-left { display: flex; align-items: center; gap: 12px; }\n    #lumoria-faq-{{ section.id }} .icon-circle { width: 34px; height: 34px; border: 1px solid #e5e5e5; border-radius: 50%; display: grid; place-items: center; }\n    #lumoria-faq-{{ section.id }} .icon-circle svg { width: 18px; height: 18px; color: #000; }\n    #lumoria-faq-{{ section.id }} .faq-title { font-size: 15px; font-weight: 600; color: #000; }\n    #lumoria-faq-{{ section.id }} .faq-plus { font-size: 18px; font-weight: 600; color: #000; transition: transform 0.2s ease; }\n    #lumoria-faq-{{ section.id }} .faq-item.open .faq-plus { transform: rotate(45deg); }\n    #lumoria-faq-{{ section.id }} .faq-body { max-height: 0; overflow: hidden; transition: max-height 0.25s ease; padding: 0 4px; }\n    #lumoria-faq-{{ section.id }} .faq-item.open .faq-body { max-height: 1000px; padding: 0 4px 14px; }\n    #lumoria-faq-{{ section.id }} .faq-body p,\n    #lumoria-faq-{{ section.id }} .faq-body ul { font-size: 14px; color: #333; line-height: 1.6; margin: 0 0 8px 0; }\n    #lumoria-faq-{{ section.id }} .faq-body ul { padding-left: 18px; list-style: disc; }\n    #lumoria-faq-{{ section.id }} .faq-sublist { border: 1px solid #eee; border-radius: 8px; overflow: hidden; }\n    #lumoria-faq-{{ section.id }} .faq-subitem + .faq-subitem { border-top: 1px solid #eee; }\n    #lumoria-faq-{{ section.id }} .faq-subhead { display: flex; align-items: center; justify-content: space-between; cursor: pointer; padding: 12px; background: #fafafa; }\n    #lumoria-faq-{{ section.id }} .faq-subleft { display: flex; gap: 10px; align-items: center; }\n    #lumoria-faq-{{ section.id }} .faq-subtitle { font-size: 14px; font-weight: 600; color: #111; }\n    #lumoria-faq-{{ section.id }} .faq-subplus { font-size: 18px; font-weight: 600; color: #000; transition: transform 0.2s ease; }\n    #lumoria-faq-{{ section.id }} .faq-subitem.open .faq-subplus { transform: rotate(45deg); }\n    #lumoria-faq-{{ section.id }} .faq-subbody { max-height: 0; overflow: hidden; transition: max-height 0.25s ease; background: #fff; padding: 0 12px; }\n    #lumoria-faq-{{ section.id }} .faq-subitem.open .faq-subbody { max-height: 800px; padding: 10px 12px 12px; }\n    #lumoria-faq-{{ section.id }} .faq-subbody p { margin: 0 0 8px; }\n  </style>\n\n  <div class=\"faq-list\">\n\n    <!-- 1 - Přehled produktu -->\n    <div class=\"faq-item\">\n      <div class=\"faq-head\">\n        <div class=\"faq-left\">\n          <span class=\"icon-circle\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\">\n              <path d=\"M3 7l9 5 9-5M3 7v10l9 5 9-5V7\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </span>\n          <span class=\"faq-title\">Přehled produktu</span>\n        </div>\n        <span class=\"faq-plus\">+</span>\n      </div>\n      <div class=\"faq-body\">\n        <p><strong>Materiál:</strong> 80% nylon, 20% elastan<br>\n        <strong>Dostupné barvy:</strong> Černá, Bílá, Šedá<br>\n        <strong>Typ:</strong> Energetické kompresní tílko Lumoria®</p>\n        <ul>\n          <li>Přináší pocit energie a sebedůvěry</li>\n          <li>Může podpořit hubnutí</li>\n          <li>Zmírňuje viditelnost gynekomastie</li>\n        </ul>\n      </div>\n    </div>\n\n    <!-- 2 - Průvodce velikostmi -->\n    <div class=\"faq-item\">\n      <div class=\"faq-head\">\n        <div class=\"faq-left\">\n          <span class=\"icon-circle\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\">\n              <path d=\"M3 7h18v10H3zM7 7v10M11 7v10M15 7v10M19 7v10\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n            </svg>\n          </span>\n          <span class=\"faq-title\">Průvodce velikostmi</span>\n        </div>\n        <span class=\"faq-plus\">+</span>\n      </div>\n      <div class=\"faq-body\">\n        <table style=\"width:100%; border-collapse:collapse;\">\n          <thead>\n            <tr><th style=\"text-align:left;\">Velikost</th><th>Odpovídající hmotnost</th></tr>\n          </thead>\n          <tbody>\n            <tr><td><strong>S</strong></td><td>45–55 kg</td></tr>\n            <tr><td><strong>M</strong></td><td>55–65 kg</td></tr>\n            <tr><td><strong>L</strong></td><td>65–75 kg</td></tr>\n            <tr><td><strong>XL</strong></td><td>75–85 kg</td></tr>\n            <tr><td><strong>2XL</strong></td><td>85–95 kg</td></tr>\n            <tr><td><strong>3XL</strong></td><td>95–105 kg</td></tr>\n            <tr><td><strong>4XL</strong></td><td>105–115 kg</td></tr>\n            <tr><td><strong>5XL</strong></td><td>115–125 kg</td></tr>\n            <tr><td><strong>6XL</strong></td><td>125–135 kg</td></tr>\n            <tr><td><strong>7XL</strong></td><td>135–145 kg</td></tr>\n          </tbody>\n        </table>\n      </div>\n    </div>\n\n    <!-- 3 - Péče o výrobek -->\n    <div class=\"faq-item\">\n      <div class=\"faq-head\">\n        <div class=\"faq-left\">\n          <span class=\"icon-circle\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\">\n              <rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\" stroke-width=\"1.5\"/>\n              <circle cx=\"12\" cy=\"13\" r=\"4\" stroke-width=\"1.5\"/>\n              <circle cx=\"8\" cy=\"7\" r=\"1\" fill=\"currentColor\"/>\n              <circle cx=\"11\" cy=\"7\" r=\"1\" fill=\"currentColor\"/>\n            </svg>\n          </span>\n          <span class=\"faq-title\">Péče o výrobek</span>\n        </div>\n        <span class=\"faq-plus\">+</span>\n      </div>\n      <div class=\"faq-body\">\n        <p>Praní v pračce <strong>na nízkou teplotu</strong> pro zachování materiálu a účinné komprese.</p>\n      </div>\n    </div>\n\n    <!-- 4 - Doprava & vrácení -->\n    <div class=\"faq-item\">\n      <div class=\"faq-head\">\n        <div class=\"faq-left\">\n          <span class=\"icon-circle\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\">\n              <path d=\"M3 7h11v8H3zM14 9h4l3 3v3h-7z\" stroke-width=\"1.5\" stroke-linejoin=\"round\"/>\n              <circle cx=\"7\" cy=\"17\" r=\"2\" />\n              <circle cx=\"17\" cy=\"17\" r=\"2\" />\n            </svg>\n          </span>\n          <span class=\"faq-title\">Doprava & vrácení</span>\n        </div>\n        <span class=\"faq-plus\">+</span>\n      </div>\n      <div class=\"faq-body\">\n        <p>Objednávky jsou <strong>zpracovány do 24 hodin</strong>.</p>\n        <p>Odhadovaná doba doručení: <strong>8 až 12 pracovních dní</strong> (číslo sledování zasláno e-mailem).</p>\n        <p>Pro dotazy ohledně velikosti nebo výměny: <a href=\"mailto:contact@getlumoria.com\">contact@getlumoria.com</a>.</p>\n      </div>\n    </div>\n\n    <!-- 5 - Často kladené otázky -->\n    <div class=\"faq-item\">\n      <div class=\"faq-head\">\n        <div class=\"faq-left\">\n          <span class=\"icon-circle\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\">\n              <path d=\"M12 3a7 7 0 0 1 4.95 11.95L16 17H8l-.95-2.05A7 7 0 0 1 12 3z\" stroke-width=\"1.5\" stroke-linejoin=\"round\"/>\n              <path d=\"M9 21h6M10.5 17v1.5M13.5 17v1.5\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n            </svg>\n          </span>\n          <span class=\"faq-title\">Často kladené otázky</span>\n        </div>\n        <span class=\"faq-plus\">+</span>\n      </div>\n      <div class=\"faq-body\">\n\n        <div class=\"faq-sublist\">\n          <!-- Q1 -->\n          <div class=\"faq-subitem\">\n            <div class=\"faq-subhead\">\n              <div class=\"faq-subleft\">\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\">\n                  <path d=\"M12 19v-2M9 8a3 3 0 1 1 6 0c0 2-3 2-3 4\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                </svg>\n                <span class=\"faq-subtitle\">Pro koho je Lumoria® určena?</span>\n              </div>\n              <span class=\"faq-subplus\">+</span>\n            </div>\n            <div class=\"faq-subbody\">\n              <p>Pro muže, kteří chtějí <strong>zlepšit držení těla</strong>, <strong>zpevnit siluetu</strong>, <strong>zvýšit energii</strong> a získat více <strong>sebedůvěry</strong> v každodenním životě.</p>\n            </div>\n          </div>\n\n          <!-- Q2 -->\n          <div class=\"faq-subitem\">\n            <div class=\"faq-subhead\">\n              <div class=\"faq-subleft\">\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\">\n                  <path d=\"M4 12h16M12 4v16\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n                </svg>\n                <span class=\"faq-subtitle\">Jak tílko Lumoria® funguje?</span>\n              </div>\n              <span class=\"faq-subplus\">+</span>\n            </div>\n            <div class=\"faq-subbody\">\n              <p>Vysoce výkonná tkanina s <strong>minerálními vlákny</strong>: podporuje <strong>krevní oběh</strong>, pomáhá udržovat <strong>vzpřímené</strong> a tonické držení těla. Při pravidelném nošení <strong>zeštíhluje siluetu</strong> a zlepšuje posturální pohodu.</p>\n            </div>\n          </div>\n\n          <!-- Q3 -->\n          <div class=\"faq-subitem\">\n            <div class=\"faq-subhead\">\n              <div class=\"faq-subleft\">\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\">\n                  <path d=\"M12 8v4l3 3\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                  <circle cx=\"12\" cy=\"12\" r=\"9\" stroke-width=\"1.5\"/>\n                </svg>\n                <span class=\"faq-subtitle\">Kdy uvidím výsledky?</span>\n              </div>\n              <span class=\"faq-subplus\">+</span>\n            </div>\n            <div class=\"faq-subbody\">\n              <p>Většina uživatelů zaznamenává rozdíl do <strong>30 dní</strong>, zejména při každodenním nošení a zdravém životním stylu.</p>\n            </div>\n          </div>\n\n          <!-- Q4 -->\n          <div class=\"faq-subitem\">\n            <div class=\"faq-subhead\">\n              <div class=\"faq-subleft\">\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\">\n                  <path d=\"M8 12l3 3 5-5\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                </svg>\n                <span class=\"faq-subtitle\">Co když velikost nesedí?</span>\n              </div>\n              <span class=\"faq-subplus\">+</span>\n            </div>\n            <div class=\"faq-subbody\">\n              <p>Kontaktujte nás na <a href=\"mailto:contact@getlumoria.com\">contact@getlumoria.com</a>: zajistíme <strong>rychlou výměnu</strong>.</p>\n            </div>\n          </div>\n\n          <!-- Q5 -->\n          <div class=\"faq-subitem\">\n            <div class=\"faq-subhead\">\n              <div class=\"faq-subleft\">\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\">\n                  <path d=\"M5 12h14M12 5v14\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n                </svg>\n                <span class=\"faq-subtitle\">Mohu ho nosit celý den?</span>\n              </div>\n              <span class=\"faq-subplus\">+</span>\n            </div>\n            <div class=\"faq-subbody\">\n              <p>Ano! Pod oblečením při každodenních aktivitách nebo <strong>při sportu</strong> pro maximální výsledky.</p>\n            </div>\n          </div>\n\n          <!-- Q6 -->\n          <div class=\"faq-subitem\">\n            <div class=\"faq-subhead\">\n              <div class=\"faq-subleft\">\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\">\n                  <rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\" stroke-width=\"1.5\"/>\n                </svg>\n                <span class=\"faq-subtitle\">Lze ho prát v pračce?</span>\n              </div>\n              <span class=\"faq-subplus\">+</span>\n            </div>\n            <div class=\"faq-subbody\">\n              <p>Ano, <strong>na nízkou teplotu</strong> pro ochranu vlákna a zachování účinnosti komprese.</p>\n            </div>\n          </div>\n\n          <!-- Q7 -->\n          <div class=\"faq-subitem\">\n            <div class=\"faq-subhead\">\n              <div class=\"faq-subleft\">\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\">\n                  <path d=\"M4 4h16v16H4z\" stroke-width=\"1.5\"/>\n                </svg>\n                <span class=\"faq-subtitle\">Jaké materiály jsou použity?</span>\n              </div>\n              <span class=\"faq-subplus\">+</span>\n            </div>\n            <div class=\"faq-subbody\">\n              <p><strong>80% nylon, 20% elastan</strong>: pružnost, podpora a prémiová prodyšnost.</p>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n  </div>\n\n  <script>\n    document.querySelectorAll(\"#lumoria-faq-{{ section.id }} .faq-head\").forEach((btn)=>{\n      btn.addEventListener(\"click\", ()=>{\n        const item = btn.parentElement;\n        item.classList.toggle(\"open\");\n      });\n    });\n\n    document.querySelectorAll(\"#lumoria-faq-{{ section.id }} .faq-subhead\").forEach((btn)=>{\n      btn.addEventListener(\"click\", (e)=>{\n        e.stopPropagation();\n        const sub = btn.parentElement;\n        sub.classList.toggle(\"open\");\n      });\n    });\n  </script>\n</div>",
