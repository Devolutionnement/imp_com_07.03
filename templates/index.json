        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "<div id=\"pdp-mbg-{{ section.id }}\" class=\"pdp-mbg__container\">\n  <style>\n    #pdp-mbg-{{ section.id }}{\n      display:flex; align-items:center; justify-content:center; gap:18px;\n      text-align:center; padding:14px 16px; background:#fff;\n    }\n    #pdp-mbg-{{ section.id }} .pdp-mbg__image img{\n      width:199px; height:auto; display:block; margin:0 auto;\n    }\n    #pdp-mbg-{{ section.id }} .pdp-mbg__text p{\n      margin:0; font-size:15px; line-height:1.6; color:#111;\n    }\n    #pdp-mbg-{{ section.id }} .pdp-mbg__text strong{ font-weight:700; }\n    /* Responsive */\n    @media (max-width: 768px){\n      #pdp-mbg-{{ section.id }}{ flex-direction:column; gap:12px; }\n      #pdp-mbg-{{ section.id }} .pdp-mbg__image img{ width:160px; }\n    }\n  </style>\n\n  <div class=\"pdp-mbg__image\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0681/1290/8348/files/image_2025-10-24_122041580.png?v=1761304783\"\n         alt=\"Garantie satisfait ou remboursé\"\n         width=\"199\" loading=\"lazy\">\n  </div>\n\n  <div class=\"pdp-mbg__text\">\n    <p>\n      <strong>Rejoignez plus de 32 300 clients satisfaits</strong> qui ont déjà franchi le pas.<br>\n      Essayez Lumoria avec notre <strong>garantie satisfait ou remboursé de 30&nbsp;jours</strong>. \n      Si ce n’est pas pour vous, nous vous remboursons.\n    </p>\n  </div>\n</div>",
