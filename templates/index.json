        "liquid": "<div id=\"lumoria-compare-{{ section.id }}\" class=\"page-width\">\n  <h2 class=\"cmp-heading\">Pourquoi Lumoria&nbsp;?</h2>\n\n  <!-- En-tête: 2 colonnes -->\n  <div class=\"cmp-head\">\n    <div class=\"cmp-col cmp-col--primary\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0681/1290/8348/files/lumoo_dif.png?v=1761303299\" alt=\"Lumoria\" />\n      <div class=\"cmp-title\">Lumoria</div>\n      <div class=\"cmp-stars\" aria-label=\"Note 4,5 sur 5\">★★★★★</div>\n    </div>\n    <div class=\"cmp-col\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0681/1290/8348/files/vboost-v2-comp-2_400x_9c27a5f3-61ef-4732-a85d-fc6703563b4c.webp?v=1767487069\" alt=\"Autres marques\" />\n      <div class=\"cmp-title\">Autres marques</div>\n      <div class=\"cmp-stars\" aria-label=\"Note 4 sur 5\">★★☆☆☆</div>\n    </div>\n  </div>\n\n  <!-- Tableau simple -->\n  <div class=\"cmp-table\">\n    <div class=\"cmp-row\">\n      <div class=\"cmp-label\">Compression confortable</div>\n      <div class=\"cmp-ok\">✓</div>\n      <div class=\"cmp-no\">✗</div>\n    </div>\n    <div class=\"cmp-row\">\n      <div class=\"cmp-label\">Tissu de qualité</div>\n      <div class=\"cmp-ok\">✓</div>\n      <div class=\"cmp-no\">✗</div>\n    </div>\n    <div class=\"cmp-row\">\n      <div class=\"cmp-label\">Invisible sous les vêtements</div>\n      <div class=\"cmp-ok\">✓</div>\n      <div class=\"cmp-no\">✗</div>\n    </div>\n    <div class=\"cmp-row\">\n      <div class=\"cmp-label\">Look de débardeur de sport</div>\n      <div class=\"cmp-ok\">✓</div>\n      <div class=\"cmp-no\">✗</div>\n    </div>\n    <div class=\"cmp-row\">\n      <div class=\"cmp-label\">Tissu premium respirant</div>\n      <div class=\"cmp-ok\">✓</div>\n      <div class=\"cmp-no\">✗</div>\n    </div>\n  </div>\n</div>\n\n<style>\n  #lumoria-compare-{{ section.id }} {\n    max-width: 980px;\n    margin: 0 auto;\n    padding: 40px 12px 0; /* ✅ padding top ajouté */\n    font-family: inherit;\n    color: #1c1d1d;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-heading {\n    text-align: center;\n    margin: 0 0 18px;\n    font-weight: 800;\n    font-size: clamp(32px, 4.5vw, 44px); /* ✅ plus grand et responsive */\n    line-height: 1.1;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-head {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 14px;\n    margin-bottom: 10px;\n    align-items: end;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-col {\n    background: #f5f5f5;\n    border-radius: 10px;\n    padding: 10px;\n    text-align: center;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-col--primary {\n    background: #27a9d8;\n    color: #fff;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-col img {\n    width: 100%;\n    height: auto;\n    border-radius: 8px;\n    display: block;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-title {\n    font-weight: 700;\n    margin: 6px 0 2px;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-stars {\n    font-size: 16px;\n    letter-spacing: 2px;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-table {\n    border-top: 1px solid #e8e8e1;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-row {\n    display: grid;\n    grid-template-columns: 1.2fr .8fr .8fr;\n    align-items: center;\n    border-bottom: 1px solid #e8e8e1;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-label {\n    background: #f7f7f7;\n    padding: 12px 14px;\n    font-weight: 600;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-ok,\n  #lumoria-compare-{{ section.id }} .cmp-no {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    padding: 12px 0;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-ok {\n    background: #27a9d8;\n    color: #fff;\n    border-left: 1px solid #e8e8e1;\n  }\n\n  #lumoria-compare-{{ section.id }} .cmp-no {\n    background: #fff;\n    color: #ff3b30;\n    border-left: 1px solid #e8e8e1;\n  }\n\n  @media (max-width: 768px) {\n    #lumoria-compare-{{ section.id }} .cmp-row {\n      grid-template-columns: 1fr .7fr .7fr;\n    }\n  }\n</style>",
